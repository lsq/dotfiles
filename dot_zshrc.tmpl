# dgt - A wrapper for 'dgit' to clone/download git repositories via proxy
# Usage: dgt <repo> <dest_dir>
# Example: dgt https://github.com/user/repo.git ./my-repo
dgt() {
    local repo=""
    local dest=""
    local proxy="https://gh-proxy.com"
    local log_prefix="log: "

    # 显示帮助信息
    show_help() {
        cat <<EOF
Usage: dgt <repository-url> <destination-directory>

Download or clone a Git repository using 'dgit' with built-in proxy and logging.

Arguments:
  <repository-url>        The URL of the Git repository (e.g., https://github.com/...)
  <destination-directory> The local path where the repo will be cloned/downloaded

Options:
  --help, -h              Show this help message and exit

Environment:
  DGT_PROXY               Override default proxy (default: https://gh-proxy.com)

Examples:
  dgt https://github.com/torvalds/linux.git ./linux
  DGT_PROXY=https://mirror.example.com dgt https://github.com/user/repo.git ./repo

Note:
  This function requires 'dgit' to be installed and available in PATH.
EOF
    }

    # 检查 dgit 是否存在
    if ! command -v dgit &> /dev/null; then
        echo "Error: 'dgit' is not installed or not found in PATH." >&2
        echo "Please install 'dgit' first." >&2
        return 1
    fi

    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                return 0
                ;;
            *)
                if [[ -z "$repo" ]]; then
                    repo="$1"
                elif [[ -z "$dest" ]]; then
                    dest="$1"
                else
                    echo "Error: Unexpected extra argument: '$1'" >&2
                    echo "Run 'dgt --help' for usage." >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    # 检查必需参数
    if [[ -z "$repo" ]]; then
        echo "Error: Missing repository URL." >&2
        echo "Run 'dgt --help' for usage." >&2
        return 1
    fi

    if [[ -z "$dest" ]]; then
        echo "Error: Missing destination directory." >&2
        echo "Run 'dgt --help' for usage." >&2
        return 1
    fi

    # 允许通过环境变量覆盖代理
    if [[ -n "${DGT_PROXY:-}" ]]; then
        proxy="$DGT_PROXY"
    fi

    # 检查目标目录是否已存在
    if [[ -e "$dest" ]]; then
        echo "Error: Destination '$dest' already exists." >&2
        return 1
    fi

    # 执行 dgit 命令
    echo "Cloning '$repo' into '$dest' via proxy '$proxy'..."
    if dgit d "$repo" -d "$dest" --log --log-prefix="$log_prefix" --proxy "$proxy" --exact-match; then
        echo "Success: Repository cloned to '$dest'."
        return 0
    else
        echo "Error: dgit command failed." >&2
        return 1
    fi
}
