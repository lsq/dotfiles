# Wrapper for chezmoi to convert ~/ to Windows path only for 'chezmoi edit'
chezmoi() {
    if [[ $# -ge 1 && "$1" == "edit" ]]; then
        # 获取当前用户的 Windows 风格主目录（适用于 MSYS2/Git Bash on Windows）
        local win_home
        if [[ -n "$HOME" ]]; then
            # 将 $HOME 从 /home/Administrator 或 /c/Users/Administrator 转换为统一的 /c/Users/Administrator
            # 使用 cygpath（如果可用）或手动转换
            # if command -v cygpath &>/dev/null; then
            # win_home=$(cygpath -u "$(cygpath -w "$HOME")")
                # 手动处理常见情况
                if [[ "$HOME" == /c/Users/* ]]; then
                    win_home="$HOME"
                elif [[ "$HOME" == /home/* ]]; then
                    # 假设用户名是 ${HOME#/home/}
                    local user="${HOME#/home/}"
                    win_home="/c/Users/$user"
                else
                    # fallback: assume standard Windows path
                    win_home="/c/Users/Administrator"
                fi
        else
            win_home="/c/Users/Administrator"
        fi

        # 构造新参数：将所有以 ~/ 开头的参数替换为 $win_home/
        local new_args=()
        for arg in "$@"; do
            if [[ "$arg" == "~/"* ]]; then
                new_args+=("${win_home}/${arg#"~/"}")
            elif [[ "$arg" == "~" ]]; then
                new_args+=("$win_home")
            else
                new_args+=("$arg")
            fi
        done

        # 调用原始 chezmoi 命令
        command chezmoi "${new_args[@]}"
    else
        # 非 edit 子命令，直接透传
        command chezmoi "$@"
    fi
}
{{- end }}
