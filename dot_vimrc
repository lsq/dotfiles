" 以下内容抄自 coc.nvim 的官网
" utf-8 byte sequence

let g:coc_config_home=$VIMFLHOME
let g:coc_data_home="~/.cache/vim/coc"
let g:coc_global_extensions = ['coc-json',  'coc-git','coc-vimlsp', 'coc-yaml', 'coc-xml', 'coc-toml', 'coc-tsserver', 'coc-prettier', 'coc-floaterm', 'coc-css', 'coc-deno', 'coc-powershell', 'coc-pyright', 'coc-snippets', 'coc-sh', 'coc-emoji', 'coc-solargraph', '@yaegassy/coc-black-formatter', '@bratel/coc-black-formatter', '@yaegassy/coc-ruff', 'coc-zig']
